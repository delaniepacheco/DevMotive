import random
from pywebio import start_server
from pywebio.input import *
from pywebio.output import *
from pywebio.session import *


# List of developer motivation messages
messages = [
    
]

def show_message():
    clear()
    put_markdown("# DevBoost")
    put_text("Your daily motivation for coding:")
    put_text("")
    
    message = random.choice(messages)
    put_success(message)
    
    put_text("")
    put_buttons(
        ["Show Another Message"],
        onclick=[lambda: show_message()]
    )

def app():
    show_message()

if __name__ == "__main__":
    start_server(app, port=8080, debug=True)
